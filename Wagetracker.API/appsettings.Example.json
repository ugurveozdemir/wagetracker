{
    "ConnectionStrings": {
        "DefaultConnection": "Host=YOUR_SUPABASE_HOST;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"
    },
    "Jwt": {
        "SecretKey": "YOUR_SECRET_KEY_HERE_MINIMUM_32_CHARACTERS_LONG",
        "Issuer": "WageTrackerAPI",
        "Audience": "WageTrackerClient",
        "ExpiryInMinutes": 1440
    },
    "Cors": {
        "AllowedOrigins": [
            "https://wagetracker.xyz",
            "https://www.wagetracker.xyz"
        ]
    },
    "ReceiptScan": {
        "Provider": "gemini",
        "Model": "gemini-2.5-flash-lite",
        "MaxImageBytes": 5242880,
        "TimeoutSeconds": 20,
        "Gemini": {
            "ApiKey": "YOUR_GEMINI_API_KEY"
        }
    },
    "RevenueCat": {
        "ApiKey": "YOUR_REVENUECAT_SECRET_API_KEY",
        "WebhookSecret": "YOUR_REVENUECAT_WEBHOOK_SECRET",
        "EntitlementId": "pro",
        "Products": {
            "Monthly": "monthly",
            "SixMonth": "six_month",
            "Annual": "yearly"
        }
    },
    "Support": {
        "Email": "support@wagetracker.xyz"
    },
    "Email": {
        "Provider": "Brevo",
        "ApiKey": "YOUR_BREVO_API_KEY",
        "FromEmail": "noreply@wagetracker.xyz",
        "FromName": "Chickaree"
    },
    "PasswordReset": {
        "Pepper": "YOUR_STRONG_RANDOM_PASSWORD_RESET_PEPPER"
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*"
}
