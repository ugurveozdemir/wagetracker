# Copy this file to .env for local development.
# Cloud builds should use the same variable names in EAS environments.
# You can mirror them locally with: npx eas-cli env:pull --environment development

IOS_BUNDLE_ID=com.ugurozdemir.chickareej1
ANDROID_PACKAGE=com.ugurozdemir.chickareej1
IOS_BUILD_NUMBER=1
ANDROID_VERSION_CODE=1
EXPO_PUBLIC_API_URL=https://api.wagetracker.xyz
EXPO_PUBLIC_API_URL_ANDROID=https://api.wagetracker.xyz
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=YOUR_REVENUECAT_PUBLIC_IOS_SDK_KEY
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=YOUR_REVENUECAT_PUBLIC_ANDROID_SDK_KEY
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
EXPO_PUBLIC_TERMS_URL=https://www.apple.com/legal/internet-services/itunes/dev/stdeula/
EXPO_PUBLIC_PRIVACY_URL=https://wagetracker.xyz/privacy
EXPO_PUBLIC_SUPPORT_EMAIL=support@wagetracker.xyz
EXPO_PUBLIC_ACCOUNT_DELETION_URL=https://api.wagetracker.xyz/account-deletion
EXPO_PUBLIC_APP_STORE_SUBSCRIPTIONS_URL=https://apps.apple.com/account/subscriptions
EXPO_PUBLIC_PLAY_STORE_SUBSCRIPTIONS_URL=https://play.google.com/store/account/subscriptions
